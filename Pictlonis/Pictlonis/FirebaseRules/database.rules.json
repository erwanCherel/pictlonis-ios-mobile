{ 
  "rules": {
    ".read": "auth != null",
    "strokes": {
      "$roomId": {
        ".read": "auth != null",
        "$strokeId": {
          ".write": "auth != null && newData.child('uid').val() === auth.uid",
          ".validate": "newData.hasChildren(['uid','color','width','points','createdAt'])"
        }
      }
    }
  }
}
